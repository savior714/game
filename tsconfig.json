{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "strict": false,
    "skipLibCheck": true,
    "lib": ["ES2020", "DOM"]
  },
  "include": ["common/**/*.js", "english/**/*.js", "korean/**/*.js", "math/**/*.js", "science/**/*.js", "global/**/*.js"],
  "exclude": ["node_modules", "docs", "archive", "**/verify_*.js", "**/test_*.js", "korean/ui.js"]
}
